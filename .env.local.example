# Notion
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Google Maps (used server-side for geocoding + passed to client for rendering)
GOOGLE_MAPS_API_KEY=AIzaSy...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# Webhook auth — generate any random string, e.g.: openssl rand -hex 32
SYNC_SECRET=your-random-secret-here

# Vercel KV (auto-injected when you add KV storage in Vercel dashboard)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
